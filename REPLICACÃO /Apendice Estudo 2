# O objetivo aqui é calcular o efeito real do tratamento de mídia usando a lógica de Diferença-em-Diferenças (DiD).

# A autora vai usar um loop para repetir o mesmo cálculo para todas as variáveis.
diffs <- t(sapply(outcome_cols_all, function(outcome) {
  
  # eliminar desistências relacionadas a resultados específicos
  d_complete <- d[ !is.na(d[outcome]) & !is.na(d[paste0(outcome,"_w2")]) ,]
  
  # calcular medías
  w1_means <- tapply(d_complete[[outcome]], d_complete$Treated, mean, na.rm=T)
  w2_means <- tapply(d_complete[[paste0(outcome,"_w2")]], d_complete$Treated, mean, na.rm=T)
  
  # calcular diferenças
  control_diff <- w2_means[1] - w1_means[1]
  treat_diff <- w2_means[2] - w1_means[2]
  did <- treat_diff - control_diff
  
  round(c(w1_means[1], w2_means[1], control_diff,
          w1_means[2], w2_means[2], treat_diff,
          did), 3)
  
}))
colnames(diffs) <- c("Control, pre","Control, post", "Control, diff.",
                     "Treated, pre","Treated, post", "Treated, diff.",
                     "Diff in diff")
rownames(diffs) <- outcome_names_all

#incluir os erros-padrão (SE) e os valores-p
SE_pval <- as.data.frame(t(sapply(outcome_cols_all, function(outcome) {
  formula <- as.formula(paste0(outcome, "_diff ~ Treated"))
  fit <- lm(formula, data=d)
  round(summary(fit)$coef["Treated",c(2,4)], 3)
})))
colnames(SE_pval) <- c("SE","p-val.")
diffs <- cbind(diffs, SE_pval)

# Comentarios:
# A análise principal do Estudo 2 fundamenta-se na técnica de Diferença-em-Diferenças (DiD). 
# Esta abordagem permite isolar o impacto causal do tratamento de mídia ao comparar a evolução das atitudes 
# climáticas no grupo experimental em relação ao grupo de controle. Ao utilizar modelos de regressão linear
# para extrair erros-padrão e p-valores, o estudo assegura que as mudanças observadas na saliência e na 
# oposição às táticas de protesto no Reino Unido possuam rigor estatístico e validade interna.

# Os resultados do Estudo 2 no Reino Unido corroboram e aprofundam os achados do Estudo 1.
# Enquanto o ativismo disruptivo consegue elevar o clima na agenda pública (Saliência) de 019 a 0.40, ele gera
# um custo político real ao alienar parte do público em relação às pautas específicas do movimento (Oposição ao Petróleo),
# sem conseguir mover as atitudes subjacentes de preocupação ou intenção de comportamento.


#Bayes factors
Bayes <- sapply(outcome_cols_all, function(outcome) {
  outcomediff <- paste0(outcome, "_diff")
  formula <- as.formula(paste0(outcomediff, " ~ Treated"))
  fit <- lmBF(formula, data=d[!is.na(d[outcomediff]),])
  extractBF(fit)[1,1]
})
diffs$Bayes <- Bayes

#n
n <- sapply(outcome_cols_all, function(outcome) {
  sum(!is.na(d[paste0(outcome, "_diff")]))
})
diffs$n <- n

#write to Latex
