# Apéndice G: Tabelas descritivas - pre/post condicion
# O objetivo aqui é calcular o efeito real do tratamento de mídia usando a lógica de Diferença-em-Diferenças (DiD).

# Configuração do Design Amostral
d_weighted <- svydesign(ids = ~1, data = d, weights = d$weight_w2)

# O Cálculo da Diferença-em-Diferenças (DiD)
# A autora vai usar um loop para repetir o mesmo cálculo para todas as variáveis.

diffs <- t(sapply(outcome_cols_all, function(outcome) {
  
  #eliminar desistências relacionadas a resultados específicos
  d_complete <- d[ !is.na(d[outcome]) & !is.na(d[paste0(outcome,"_w2")]) ,]
  
  #fazer com que as colunas “resultado” contenham a variável de resultado atual 
  d_complete$outcome <- d_complete[[outcome]]
  d_complete$outcome_w2 <- d_complete[[paste0(outcome,"_w2")]]
  
  #calcular a média da onda 1 (ponderada pelos pesos da onda 2)
  w1_means <- d_complete %>%
    group_by(Treated) %>%
    summarise(weighted_mean = sum(outcome * weight_w2) / sum(weight_w2))
  #extrair as médias do grupo de controle e do grupo tratado
  w1_means <- as.vector(w1_means[,2]$weighted_mean)
  
  #calcular a média da onda 2 (ponderada pelos pesos da onda 2)
  w2_means <- d_complete %>%
    group_by(Treated) %>%
    summarise(weighted_mean = sum(outcome_w2 * weight_w2) / sum(weight_w2))
  #extrair as médias do grupo de controle e do grupo tratado
  w2_means <- as.vector(w2_means[,2]$weighted_mean)
  
  #calcular diferenças
  control_diff <- w2_means[1] - w1_means[1]
  treat_diff <- w2_means[2] - w1_means[2]
  did <- treat_diff - control_diff
  
  round(c(w1_means[1], w2_means[1], control_diff,
          w1_means[2], w2_means[2], treat_diff,
          did), 3)
  
}))
colnames(diffs) <- c("Control, pre","Control, post", "Control, diff.",
                     "Treated, pre","Treated, post", "Treated, diff.",
                     "Diff in diff")
