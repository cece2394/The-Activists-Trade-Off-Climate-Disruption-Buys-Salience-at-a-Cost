#Função para obter tabelas de frequência ponderadas (com pesos) e não ponderadas

get_props <- function(var, d){
  # Calcula o peso total para cada nível da variável (ex: quantos homens vs mulheres)
  proportions <- aggregate(weight_w2 ~ get(var), data = d, FUN = sum)
  # Rename columns for clarity
  colnames(proportions) <- c("demographic", "weighted_sum")
  # Calcula a proporção ponderada dividindo pela soma total dos pesos
  proportions$weighted_prop <- proportions$weighted_sum / sum(d$weight_w2)
  # Adiciona as proporções brutas (sem peso) para comparação
  proportions$unweighted_prop <- prop.table(table(d[var]))
  # Mantenha apenas as colunas relevantes
  proportions <- proportions[, c("demographic", "unweighted_prop", "weighted_prop")]
  
  return(proportions)
  
}

